# メイン処理
main_process() {
    # モードに応じて処理を分岐
    if [[ "${CUSTOM_WINDOW_WITH_MESSAGE:-false}" == "true" ]]; then
        main_process_custom_window_with_message
        return
    elif [[ "${SMART_MODE:-false}" == "true" ]]; then
        main_process_smart_mode
        return
    elif [[ "${AUTO_WINDOW:-false}" == "true" ]]; then
        main_process_auto_window
        return
    elif [[ "${GENERATE_ONLY:-false}" == "true" ]]; then
        main_process_generate_only
        return
    elif [[ "${CUSTOM_WINDOW:-false}" == "true" ]]; then
        main_process_custom_window
        return
    elif [[ "${DIRECT_COMMIT:-false}" == "true" ]]; then
        main_process_direct_commit
        return
    elif [[ "${LAZYGIT_COMMIT:-false}" == "true" ]]; then
        main_process_lazygit_commit
        return
    elif [[ "${COMMIT_MODE:-false}" == "true" ]]; then
        main_process_commit
        return
    elif [[ "${LAZYGIT_MODE:-false}" == "true" ]]; then
        main_process_lazygit
        return
    fi

    log_info "コミットメッセージ生成プロセスを開始..."

    # UI初期化
    setup_signal_handlers

    # 確認ダイアログ表示
    if ! show_confirmation "AIコミットメッセージ生成" "生成AIがコミットメッセージを作成します"; then
        log_info "ユーザーによってキャンセルされました"
        exit 0
    fi

    # ローディング表示開始
    start_spinner "ステージされたファイルを分析中..."

    # Git diff分析
    log_debug "Git diff分析を実行中..."
    local file_analysis
    if ! file_analysis=$(analyze_files 2>/dev/null); then
        stop_spinner
        handle_error "${ERROR_CODES["GIT_NO_STAGED_FILES"]}"
    fi

    # Git diff取得
    local diff_content
    if ! diff_content=$(get_git_diff 2>/dev/null); then
        stop_spinner
        handle_error "${ERROR_CODES["GIT_DIFF_ERROR"]}"
    fi

    stop_spinner
    show_success "ファイル分析完了"

    # ドライランモード
    if [[ "${DRY_RUN:-false}" == "true" ]]; then
        echo "=== ドライランモード ==="
        echo "分析結果:"
        if command -v jq >/dev/null 2>&1; then
            echo "$file_analysis" | jq .
        elif command -v python3 >/dev/null 2>&1; then
            echo "$file_analysis" | python3 -m json.tool 2>/dev/null || echo "$file_analysis"
        else
            echo "$file_analysis"
        fi
        echo
        echo "Diff サマリー:"
        echo "$(echo "$diff_content" | head -20)"
        echo "..."
        log_info "ドライラン完了"
        exit 0
    fi

    # Gemini CLIでメッセージ生成
    start_spinner "AIコミットメッセージを生成中..."

    local commit_message
    if ! commit_message=$(generate_commit_message "$diff_content" "$file_analysis" 2>>"${LOG_FILE:-/dev/stderr}"); then
        stop_spinner
        handle_recoverable_error "${ERROR_CODES["GEMINI_API_ERROR"]}" \
            "手動でコミットメッセージを入力してください（詳細ログ: ${LOG_FILE:-標準エラー出力}）" || true
        exit "${ERROR_CODES["GEMINI_API_ERROR"]}"
    fi

    stop_spinner
    show_success "コミットメッセージ生成完了"

    # メッセージをLazygitに返す
    return_to_lazygit "$commit_message"

    log_info "プロセス正常完了"
}

# メイン関数
main() {
    # エラーハンドラー設定
    setup_error_handlers

    # 引数解析
    parse_arguments "$@"

    # 環境設定
    setup_environment

    # 前提条件チェック
    check_prerequisites

    # メイン処理実行
    main_process

    # クリーンアップ
    cleanup_ui

    exit 0
}

