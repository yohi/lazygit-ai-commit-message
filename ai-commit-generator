# バージョン情報を表示
show_version() {
    echo "AI Commit Generator v${VERSION}"
    echo "作者: ${AUTHOR}"
    echo
    echo "システム情報:"
    echo "  OS: $(uname -s) $(uname -r)"
    echo "  シェル: ${SHELL:-unknown}"
    echo "  Git: $(git --version 2>/dev/null || echo 'Not installed')"
    echo "  Gemini CLI: $(command -v gemini >/dev/null 2>&1 && command -v gemini || echo 'Not installed')"
}

# コマンドライン引数を解析
parse_arguments() {
    local dry_run=false
    local custom_config=""
    local custom_log_level=""
    local lazygit_mode=false
    local commit_mode=false
    local lazygit_commit=false
    local direct_commit=false
    local custom_window=false
    local generate_only=false
    local auto_window=false
    local smart_mode=false
    local enhanced_mode=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_usage
                exit 0
                ;;
            -v|--version)
                show_version
                exit 0
                ;;
            -c|--config)
                if [[ -z "${2:-}" ]] || [[ "${2:-}" == -* ]]; then
                    echo "エラー: --config オプションには設定ファイルのパスが必要です" >&2
                    echo "使用方法: $0 --config /path/to/config.yml" >&2
                    exit 1
                fi
                custom_config="$2"
                shift 2
                ;;
            -l|--log-level)
                if [[ -z "${2:-}" ]] || [[ "${2:-}" == -* ]]; then
                    echo "エラー: --log-level オプションにはログレベルが必要です" >&2
                    echo "使用方法: $0 --log-level debug" >&2
                    exit 1
                fi
                custom_log_level="$2"
                shift 2
                ;;
            --generate-sample-config)
                generate_sample_config
                exit 0
                ;;
            --diagnose)
                diagnose_system
                exit 0
                ;;
            --test-gemini)
                local test_script
                test_script="$(find_script test_gemini.sh)"
                if [[ -n "$test_script" && -x "$test_script" ]]; then
                    "$test_script"
                else
                    echo "❌ エラー: test_gemini.sh が見つからないか実行可能ではありません" >&2
                    exit 1
                fi
                exit 0
                ;;
            --debug-gemini)
                local debug_script
                debug_script="$(find_script debug_gemini.sh)"
                if [[ -n "$debug_script" && -x "$debug_script" ]]; then
                    "$debug_script"
                else
                    echo "❌ エラー: debug_gemini.sh が見つからないか実行可能ではありません" >&2
                    exit 1
                fi
                exit 0
                ;;
            --check-env)
                local env_script
                env_script="$(find_script env_check.sh)"
                if [[ -n "$env_script" && -x "$env_script" ]]; then
                    exec "$env_script"
                else
                    echo "❌ エラー: env_check.sh が見つからないか実行可能ではありません" >&2
                    exit 1
                fi
                ;;
            --dry-run)
                dry_run=true
                shift
                ;;
            --lazygit-mode)
                lazygit_mode=true
                shift
                ;;
            --commit-mode)
                commit_mode=true
                shift
                ;;
            --lazygit-commit)
                lazygit_commit=true
                shift
                ;;
            --direct-commit)
                direct_commit=true
                shift
                ;;
            --custom-window)
                custom_window=true
                shift
                ;;
            --generate-only)
                generate_only=true
                shift
                ;;
            --auto-window)
                auto_window=true
                shift
                ;;
            --smart-mode)
                smart_mode=true
                shift
                ;;
            --enhanced-mode)
                enhanced_mode=true
                shift
                ;;
            --custom-window-with-message)
                # 内部用オプション（環境変数からメッセージを受け取り）
                export CUSTOM_WINDOW_WITH_MESSAGE="true"
                shift
                ;;
            *)
                echo "エラー: 不明なオプション: $1" >&2
                echo "使用方法については --help を参照してください" >&2
                exit 1
                ;;
        esac
    done

    # グローバル変数に設定
    export DRY_RUN="$dry_run"
    export CUSTOM_CONFIG="$custom_config"
    export CUSTOM_LOG_LEVEL="$custom_log_level"
    export LAZYGIT_MODE="$lazygit_mode"
    export COMMIT_MODE="$commit_mode"
    export LAZYGIT_COMMIT="$lazygit_commit"
    export DIRECT_COMMIT="$direct_commit"
    export CUSTOM_WINDOW="$custom_window"
    export GENERATE_ONLY="$generate_only"
    export AUTO_WINDOW="$auto_window"
    export SMART_MODE="$smart_mode"
    export ENHANCED_MODE="$enhanced_mode"
}

# 環境変数を設定
setup_environment() {
    # Lazygitモードまたはコミットモードの場合はログを詳細化
    if [[ "${LAZYGIT_MODE:-false}" == "true" ]] || [[ "${COMMIT_MODE:-false}" == "true" ]] || [[ "${LAZYGIT_COMMIT:-false}" == "true" ]] || [[ "${DIRECT_COMMIT:-false}" == "true" ]] || [[ "${CUSTOM_WINDOW:-false}" == "true" ]] || [[ "${GENERATE_ONLY:-false}" == "true" ]] || [[ "${AUTO_WINDOW:-false}" == "true" ]] || [[ "${SMART_MODE:-false}" == "true" ]] || [[ "${ENHANCED_MODE:-false}" == "true" ]]; then
        export LOG_LEVEL="info"
        export LOG_FILE="/tmp/ai-commit-generator.log"
        # ログディレクトリを作成
        mkdir -p "$(dirname "$LOG_FILE")"
        # ログファイルにタイムスタンプ付きヘッダーを追加
        echo "=== AI Commit Generator ログ開始 ===" >> "$LOG_FILE"
        echo "開始時刻: $(date)" >> "$LOG_FILE"
        echo "実行モード: ${LAZYGIT_MODE:+Lazygit}${COMMIT_MODE:+Commit}${LAZYGIT_COMMIT:+LazygitCommit}${DIRECT_COMMIT:+DirectCommit}${CUSTOM_WINDOW:+CustomWindow}${GENERATE_ONLY:+GenerateOnly}${AUTO_WINDOW:+AutoWindow}${SMART_MODE:+SmartMode}" >> "$LOG_FILE"
        echo "======================================" >> "$LOG_FILE"
    else
        # ログレベルを設定
        if [[ -n "${CUSTOM_LOG_LEVEL:-}" ]]; then
            export LOG_LEVEL="$CUSTOM_LOG_LEVEL"
        else
            export LOG_LEVEL=$(get_config_value '.logging.level' 'info')
        fi

        # ログファイルを設定
        local log_file=$(get_config_value '.logging.file' '')
        if [[ -n "$log_file" ]]; then
            export LOG_FILE="$log_file"
            # ログディレクトリを作成
            mkdir -p "$(dirname "$log_file")"
        fi
    fi

    log_info "AI Commit Generator v${VERSION} を開始"
    log_debug "環境設定完了 - ログレベル: $LOG_LEVEL"
}

# 前提条件をチェック
check_prerequisites() {
    log_info "前提条件をチェック中..."

    # Gitリポジトリチェック
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        handle_error "${ERROR_CODES["GIT_NOT_REPOSITORY"]}"
    fi

    # Gemini CLIチェック
    if ! check_gemini_cli; then
        handle_error "${ERROR_CODES["GEMINI_CLI_NOT_FOUND"]}"
    fi

    # 設定ファイル検証
    if ! validate_config; then
        handle_error "${ERROR_CODES["CONFIG_INVALID"]}"
    fi

    log_info "前提条件チェック完了"
}

# コミットテンプレートを設定
set_commit_template() {
    local message="$1"
    local template_file="/tmp/ai-commit-template.txt"

    # コミットメッセージをテンプレートファイルに保存
    echo "$message" > "$template_file"

    # Gitのコミットテンプレートを設定
    git config commit.template "$template_file"

    log_debug "コミットテンプレートを設定: $template_file"
}

# コミットテンプレートをクリア
clear_commit_template() {
    # 既存のコミットテンプレート設定を削除
    git config --unset commit.template 2>/dev/null || true

    # 一時テンプレートファイルを削除
    rm -f "/tmp/ai-commit-template.txt" 2>/dev/null || true

    log_debug "コミットテンプレートをクリア"
}

# Lazygitコミット処理用エラーハンドラー
handle_lazygit_commit_error() {
    local exit_code=$1
    local line_number=$2
    echo ""
    echo "❌ エラーが発生しました (終了コード: $exit_code, 行: $line_number)"
    echo "📝 エラー詳細をログに記録中..."

    # ログファイルに詳細を記録
    {
        echo "$(date): Lazygit commit error occurred"
        echo "Exit code: $exit_code"
        echo "Line number: $line_number"
        echo "Script: $0"
        echo "Working directory: $(pwd)"
        echo "Git status:"
        git status 2>&1 || echo "Git status failed"
        echo "---"
    } >> "/tmp/ai-commit-generator.log" 2>/dev/null || true

    echo "⚠️  手動でコミット画面を開いてください ('c'キー)"
    exit $exit_code
}

# Lazygitモード用のメイン処理（新しい統合フロー）
main_process_lazygit() {
    log_info "🚀 新統合フロー: ファイルステージング → AI生成 → 自作ウィンドウ → コミット"

    # Git diff分析
    log_info "📊 ステージされたファイルを分析中..."
    local file_analysis
    if ! file_analysis=$(analyze_files 2>/dev/null); then
        log_error "❌ エラー: ステージされたファイルがありません"
        echo "ファイルをステージしてから再実行してください。"
        exit 1
    fi

    # Git diff取得
    local diff_content
    if ! diff_content=$(get_git_diff 2>/dev/null); then
        log_error "❌ エラー: Git diffの取得に失敗しました"
        exit 1
    fi

    log_info "✅ ファイル分析完了"

    # Gemini CLIでメッセージ生成
    log_info "🧠 Gemini AIでコミットメッセージを生成中..."
    local commit_message
    if ! commit_message=$(generate_commit_message "$diff_content" "$file_analysis" 2>>"${LOG_FILE:-/dev/stderr}"); then
        log_error "❌ エラー: AIコミットメッセージの生成に失敗しました"
        echo "手動でコミットメッセージを入力してください。"
        echo "詳細ログ: ${LOG_FILE:-標準エラー出力}"
        exit 1
    fi

    # コミットメッセージからログを除去してクリーンアップ（最後の行のみを取得）
    commit_message=$(echo "$commit_message" | grep -v "^\[20[0-9][0-9]-" | grep -v "INFO" | grep -v "DEBUG" | tail -1)

    log_info "✅ コミットメッセージ生成完了"
    log_info "📝 生成されたコミットメッセージ: $commit_message"

    # AI生成メッセージが事前入力された自作ウィンドウを起動
    log_info "🖥️  自作コミットメッセージ編集ウィンドウを起動中..."
    log_info "💡 生成されたメッセージが事前入力された状態で表示されます"
    
    local edited_message
    if edited_message=$(show_ai_commit_window "$commit_message" 2>/dev/null); then
        # ログ情報を除去してクリーンなメッセージのみを抽出
        edited_message=$(echo "$edited_message" | grep -v "^\[20[0-9][0-9]-" | grep -v "INFO" | grep -v "DEBUG" | grep -v "✅" | grep -v "🖥️" | grep -v "エディター" | tail -1)
        
        log_info "✅ メッセージが編集/確認されました"
        log_info "📝 最終メッセージ: $edited_message"
        
        # 確認してコミット実行（Lazygitモードでは簡略化された確認）
        if confirm_and_commit "$edited_message" "true"; then
            log_info "🎉 コミット完了！統合フローが正常に終了しました"
            echo "🎉 コミット完了！"
        else
            log_info "コミットがキャンセルまたは失敗しました"
            echo "⚠️  コミットがキャンセルされました"
            exit 1
        fi
    else
        log_warn "⚠️  コミットメッセージ編集ウィンドウがキャンセルされました"
        echo "⚠️  操作がキャンセルされました"
        exit 1
    fi
}

# Lazygitコミット統合用のメイン処理
main_process_lazygit_commit() {
    log_info "🚀 AI生成 + Lazygitコミット統合モード"

    # エラーハンドリングを強化
    set -e
    trap 'handle_lazygit_commit_error $? $LINENO' ERR

    # Git diff分析
    log_info "📊 ステージされたファイルを分析中..."
    local file_analysis
    if ! file_analysis=$(analyze_files 2>/dev/null); then
        log_error "❌ エラー: ステージされたファイルがありません"
        echo "ファイルをステージしてから再実行してください。"
        exit 1
    fi

    # Git diff取得
    local diff_content
    if ! diff_content=$(get_git_diff 2>/dev/null); then
        log_error "❌ エラー: Git diffの取得に失敗しました"
        exit 1
    fi

    log_info "✅ ファイル分析完了"

    # Gemini CLIでメッセージ生成
    log_info "🧠 Gemini AIでコミットメッセージを生成中..."
    local commit_message
    if ! commit_message=$(generate_commit_message "$diff_content" "$file_analysis" 2>>"${LOG_FILE:-/dev/stderr}"); then
        log_error "❌ エラー: AIコミットメッセージの生成に失敗しました"
        echo "手動でコミットメッセージを入力してください。"
        echo "詳細ログ: ${LOG_FILE:-標準エラー出力}"
        exit 1
    fi

    log_info "✅ コミットメッセージ生成完了"
    log_info "📝 生成されたコミットメッセージ: $commit_message"

    # コミットテンプレートを設定
    set_commit_template "$commit_message"

    log_info "📝 コミットテンプレートを設定完了"
    log_info "📋 生成されたコミットメッセージ: $(cat /tmp/ai-commit-template.txt 2>/dev/null || echo '取得失敗')"
    log_info "🎯 コミット概要編集ウィンドウを自動起動準備中..."

    # プログレスバー表示をログに記録
    log_info "⏳ 最終準備中..."
    for i in {1..10}; do
        sleep 0.1
    done
    log_info "⏳ 最終準備完了"

    log_info "🎉 AI生成完了！"
    log_info "📝 生成されたメッセージがコミット画面に自動入力されます"
    log_info "🔄 コミット概要編集ウィンドウを自動起動準備中..."
    log_info "手順: 1. Escapeキーを押してこのウィンドウを閉じる 2. 3秒後に自動的にコミット画面が開きます"
    log_info "💡 準備完了！Escapeキーを押してください..."

    # 別プロセスで自動コミットウィンドウ表示スクリプトを実行
    local auto_commit_script
    auto_commit_script="$(find_script lazygit_auto_commit.sh)"
    if [[ -n "$auto_commit_script" && -x "$auto_commit_script" ]]; then
        nohup "$auto_commit_script" >/dev/null 2>&1 &
    else
        log_error "❌ エラー: lazygit_auto_commit.sh が見つからないか実行可能ではありません"
        exit 1
    fi

    log_info "🔍 デバッグ情報: ログファイル /tmp/lazygit_auto_commit.log"
    log_info "自動コミットウィンドウ表示スクリプトがバックグラウンドで実行中..."
    log_info "💡 ヒント: 自動的にコミット画面が開きます / 生成されたメッセージを確認・編集 / Ctrl+Enterでコミット"
}

# コミットモード用のメイン処理
main_process_commit() {
    log_info "🚀 AI生成 + 自動コミット モード"

    # Git diff分析
    log_info "📊 ステージされたファイルを分析中..."
    local file_analysis
    if ! file_analysis=$(analyze_files 2>/dev/null); then
        log_error "❌ エラー: ステージされたファイルがありません"
        echo "ファイルをステージしてから再実行してください。"
        exit 1
    fi

    # Git diff取得
    local diff_content
    if ! diff_content=$(get_git_diff 2>/dev/null); then
        log_error "❌ エラー: Git diffの取得に失敗しました"
        exit 1
    fi

    log_info "✅ ファイル分析完了"

    # Gemini CLIでメッセージ生成
    log_info "🧠 Gemini AIでコミットメッセージを生成中..."
    local commit_message
    if ! commit_message=$(generate_commit_message "$diff_content" "$file_analysis" 2>>"${LOG_FILE:-/dev/stderr}"); then
        log_error "❌ エラー: AIコミットメッセージの生成に失敗しました"
        echo "手動でコミットメッセージを入力してください。"
        echo "詳細ログ: ${LOG_FILE:-標準エラー出力}"
        exit 1
    fi

    log_info "✅ コミットメッセージ生成完了"
    log_info "📝 生成されたコミットメッセージ: $commit_message"

    # 一時ファイルにメッセージを保存
    local temp_file="/tmp/ai-commit-message.txt"
    echo "$commit_message" > "$temp_file"

    log_info "🎯 コミットエディタを起動中..."
    log_info "メッセージを確認・編集してコミットを完了してください"

    # Gitコミットエディタを起動（メッセージを事前入力）
    if git commit --edit --file="$temp_file"; then
        log_info "🎉 コミット完了！"
        log_info "✅ AIが生成したメッセージでコミットされました"

        # 一時ファイルを削除
        rm -f "$temp_file"
    else
        local exit_code=$?
        log_warn "⚠️  コミットがキャンセルまたは失敗しました"

        # 一時ファイルを削除
        rm -f "$temp_file"

        exit $exit_code
    fi
}

