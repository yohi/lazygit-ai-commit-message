    log_info "🧠 Gemini AIでコミットメッセージを生成中..."
    local commit_message
    if ! commit_message=$(generate_commit_message "$diff_content" "$file_analysis" 2>>"${LOG_FILE:-/dev/stderr}"); then
        log_error "❌ エラー: AIコミットメッセージの生成に失敗しました"
        echo "手動でコミットメッセージを入力してください。"
        echo "詳細ログ: ${LOG_FILE:-標準エラー出力}"
        exit 1
    fi

    # コミットメッセージからログ行を除去して実際のメッセージのみを抽出
    local clean_message
    
    # まず、明らかに良いメッセージがあるかチェック
    clean_message=$(echo "$commit_message" | grep -E "^[0-9]+個.*追加$|^[0-9]+個.*更新$|^[0-9]+個.*削除$|^[0-9]+個.*変更$|^新しいファイルを追加$|^ファイルを更新$|^ファイルを削除$|^ファイルを変更$|^変更をコミット$" | head -1)
    
    # 良いメッセージが見つからない場合、一般的なクリーニングを実行
    if [[ -z "$clean_message" ]]; then
        clean_message=$(echo "$commit_message" | grep -v "^\[" | grep -v "INFO" | grep -v "DEBUG" | grep -v "WARN" | grep -v "ERROR" | grep -v "Gemini CLI" | grep -v "プロンプト" | grep -v "レスポンス" | grep -v "実行中" | grep -v "送信中" | grep -v "受信" | grep -v "処理中" | grep -v "生成" | grep -v "^$" | grep -v "^?" | head -1 | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    fi
    
    # まだ空の場合、最終フォールバック
    if [[ -z "$clean_message" ]]; then
        # ファイル状態から直接生成
        local added_files=$(git diff --cached --name-status | grep "^A" | wc -l)
        local modified_files=$(git diff --cached --name-status | grep "^M" | wc -l)
        local deleted_files=$(git diff --cached --name-status | grep "^D" | wc -l)
        
        if [[ $added_files -gt 0 ]] && [[ $modified_files -eq 0 ]] && [[ $deleted_files -eq 0 ]]; then
            if [[ $added_files -eq 1 ]]; then
                clean_message="新しいファイルを追加"
            else
                clean_message="${added_files}個のファイルを追加"
            fi
        elif [[ $modified_files -gt 0 ]] && [[ $added_files -eq 0 ]] && [[ $deleted_files -eq 0 ]]; then
            if [[ $modified_files -eq 1 ]]; then
                clean_message="ファイルを更新"
            else
                clean_message="${modified_files}個のファイルを更新"
            fi
        elif [[ $deleted_files -gt 0 ]] && [[ $added_files -eq 0 ]] && [[ $modified_files -eq 0 ]]; then
            if [[ $deleted_files -eq 1 ]]; then
                clean_message="ファイルを削除"
            else
                clean_message="${deleted_files}個のファイルを削除"
            fi
        else
            local total_files=$((added_files + modified_files + deleted_files))
            if [[ $total_files -eq 1 ]]; then
                clean_message="ファイルを変更"
            else
                clean_message="${total_files}個のファイルを変更"
            fi
        fi
    fi

    log_info "✅ コミットメッセージ生成完了"
    log_info "📝 クリーンなコミットメッセージ: $clean_message"

    # 直接コミットスクリプトを実行
    log_info "🎯 ユーザー確認付き直接コミットを開始"
    # 直接コミットスクリプトを探して実行
    local script_path
    script_path="$(find_script lazygit_direct_commit.sh)"
    if [[ -z "$script_path" ]]; then
        log_error "lazygit_direct_commit.sh が見つかりません"
        echo "❌ エラー: 必要なスクリプトファイルが見つかりません"
        exit 1
    fi
    
    exec "$script_path" "$clean_message"
}

