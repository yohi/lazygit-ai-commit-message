#!/bin/bash
# AI Commit Generator メインスクリプト
# Lazygit用AIコミットメッセージ生成プラグイン

set -euo pipefail

# 終了時にcommit.templateをクリーンアップ
cleanup_on_exit() {
    # コミットテンプレートをクリア
    git config --unset commit.template 2>/dev/null || true
    # 一時テンプレートファイルを削除
    rm -f "/tmp/ai-commit-template.txt" 2>/dev/null || true
}

# EXIT trapでクリーンアップを実行
trap cleanup_on_exit EXIT

# ポータブルなsymlinkの解決
resolve_symlink() {
    local target="$1"
    while [[ -L "$target" ]]; do
        local link_target
        if command -v readlink >/dev/null 2>&1; then
            link_target="$(readlink "$target")"
        else
            # readlinkが利用できない場合のフォールバック
            link_target="$(ls -l "$target" | sed 's/.*-> //')"
        fi
        
        # 相対パスの場合は絶対パスに変換
        if [[ "${link_target:0:1}" != "/" ]]; then
            target="$(dirname "$target")/$link_target"
        else
            target="$link_target"
        fi
    done
    echo "$target"
}

# スクリプトのディレクトリを取得（環境変数で上書き可能）
MAIN_SCRIPT_PATH="$(resolve_symlink "${BASH_SOURCE[0]}")"
MAIN_SCRIPT_DIR="$(cd "$(dirname "$MAIN_SCRIPT_PATH")" && pwd)"

# AI_COMMIT_SCRIPTS_DIR環境変数で上書き可能
AI_COMMIT_SCRIPTS_DIR="${AI_COMMIT_SCRIPTS_DIR:-$MAIN_SCRIPT_DIR}"
SRC_DIR="${AI_COMMIT_SCRIPTS_DIR}/src"

# スクリプトパスを解決する関数（ポータブル版）
find_script() {
    local script_name="$1"
    if [[ -f "${AI_COMMIT_SCRIPTS_DIR}/scripts/${script_name}" ]]; then
        echo "${AI_COMMIT_SCRIPTS_DIR}/scripts/${script_name}"
    else
        echo ""
    fi
}

# 依存スクリプトを読み込み
source "${SRC_DIR}/logger.sh"
source "${SRC_DIR}/config_loader.sh"
source "${SRC_DIR}/error_handler.sh"
source "${SRC_DIR}/ui_helper.sh"
source "${SRC_DIR}/git_analyzer.sh"
source "${SRC_DIR}/gemini_client.sh"
source "${SRC_DIR}/commit_window.sh"

# バージョン情報
VERSION="1.0.0"
AUTHOR="AI Commit Generator"

# 使用方法を表示
show_usage() {
    cat <<EOF
AI Commit Generator v${VERSION}

使用方法:
  ai-commit-generator [オプション]

オプション:
  -h, --help              このヘルプを表示
  -v, --version           バージョン情報を表示
  -c, --config <file>     設定ファイルを指定
  -l, --log-level <level> ログレベルを設定 (debug|info|warn|error)
  --generate-sample-config サンプル設定ファイルを生成
  --diagnose              システム診断を実行
  --test-gemini           Gemini CLI接続テストを実行
  --debug-gemini          Gemini CLI詳細デバッグを実行
  --check-env             環境変数チェックを実行
  --dry-run               実際の生成なしでプロセスをテスト
  --lazygit-mode          Lazygit統合モード（スピナー表示、結果をstdoutに出力）
  --commit-mode           AI生成後に自動でコミットエディタを開く
  --lazygit-commit        AI生成後にLazygitコミット画面を自動表示
  --direct-commit         AI生成後にユーザー確認して直接コミット（Wayland対応）
  --custom-window         AI生成後にカスタムコミットウィンドウを表示（TUI）
  --generate-only         AIメッセージ生成のみ（ウィンドウ表示なし）
  --auto-window           AI生成完了後に自動でカスタムウィンドウを起動
